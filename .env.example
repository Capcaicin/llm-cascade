# Example environment variables for AI STACK
# Copy to .env and fill values (do NOT commit .env)

# AnythingLLM API — base host ONLY; http.py adds /api/v1/... itself
ANYTHINGLLM_API_KEY=
ANYTHINGLLM_BASE_URL=http://localhost:3001

# Browser extension key (if used)
BROWSER_EXT_KEY=
BROWSER_EXT_API=http://localhost:3001

# Ollama base URL + optional API key (for hosted or secured local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Router primary models (abliterated / uncensored — default)
ROUTER_SMALL_MODEL=huihui_ai/qwen3.5-abliterated:4b
ROUTER_BIG_MODEL=huihui_ai/qwen3.5-abliterated:35b

# Free / fast Ollama models used as subagent targets (safe tasks only)
ROUTER_FAST_DRAFT_MODEL=llama3.1:8b
ROUTER_FAST_CRITIC_MODEL=mistral:latest
ROUTER_FAST_CODER_MODEL=qwen2.5-coder:14b

# Router server URL — Streamlit and OpenClaw both talk here
ROUTER_SERVER_URL=http://localhost:3839

# Optional: private workspace password (leave blank to disable gating)
PRIVATE_PASSWORD=
