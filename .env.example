# Example environment variables for AI STACK.
# Copy to `.env` and fill values. Do NOT commit `.env` — it's gitignored.
#
# Preferred: store secrets in the OS keyring instead of this file:
#     python -m core.keyring_helper set <account>
# The router resolves keyring first, env second. See SETUP.md "Migration
# Guide — plaintext .env → OS keyring" for the one-time migration.

# ─────────────────────────────────────────────────────────────────────────────
# Secrets (keyring-aware — leave blank once migrated)
# ─────────────────────────────────────────────────────────────────────────────

# AnythingLLM API key.        keyring account: anythingllm
ANYTHINGLLM_API_KEY=

# Browser-extension API key.  keyring account: browser-ext
BROWSER_EXT_KEY=

# Optional Ollama API key (for hosted / secured Ollama).  keyring account: ollama
OLLAMA_API_KEY=

# Private-workspace password for the Streamlit dashboard gate.
# Leaving this blank keeps the workspace locked (fail-closed) — every
# unlock attempt is rejected. Prefer the keyring:
#     python -m core.keyring_helper set private-password
# keyring account: private-password
PRIVATE_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Service endpoints
# ─────────────────────────────────────────────────────────────────────────────

# AnythingLLM base host ONLY; http.py adds `/api/v1/…` itself.
ANYTHINGLLM_BASE_URL=http://localhost:3001

# Browser extension bridge (usually same host as AnythingLLM).
BROWSER_EXT_API=http://localhost:3001

# Ollama base URL.
OLLAMA_BASE_URL=http://localhost:11434

# Router server URL — Streamlit and OpenClaw both talk here.
ROUTER_SERVER_URL=http://localhost:3839

# ─────────────────────────────────────────────────────────────────────────────
# Router model catalog
# ─────────────────────────────────────────────────────────────────────────────

# Primary pair (abliterated / uncensored — default for anything user-facing).
ROUTER_SMALL_MODEL=huihui_ai/qwen3.5-abliterated:4b
ROUTER_BIG_MODEL=huihui_ai/qwen3.5-abliterated:35b

# Free / fast Ollama models used as subagent targets for safe tasks only.
# The sorter decides which of these to dispatch when `router-fast` is active
# and the task is flagged `safe_for_free_model=true`.
ROUTER_FAST_DRAFT_MODEL=llama3.1:8b
ROUTER_FAST_CRITIC_MODEL=mistral:latest
ROUTER_FAST_CODER_MODEL=qwen2.5-coder:14b

# ─────────────────────────────────────────────────────────────────────────────
# Router behavior knobs
# ─────────────────────────────────────────────────────────────────────────────

# Auto-refine — when the sorter flags `needs_refinement=true`, the router
# runs router-sub-critic over the 35b draft and re-runs the 35b with the
# critique folded in (~2× latency, tighter answer). `0` / `false` / `off`
# disables. Default: 1.
# ROUTER_AUTO_REFINE=1

# Per-IP sliding-window rate limit. Localhost / host.docker.internal are
# always exempt so the dashboard and Docker compose networking don't trip
# it. `0` disables the limiter entirely. Default: 120.
# ROUTER_RATE_LIMIT_PER_MIN=120

# CORS origins for the router (comma-separated). Default allows Streamlit
# on 8501 and Vite on 3000 via both `localhost` and `127.0.0.1`. `*` allows
# any origin but drops credentials per spec — only safe on a strictly
# localhost-bound deployment.
# ROUTER_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:3000,http://127.0.0.1:3000

# Memory recall depth — how many recent summaries to inject as a system
# block per request. Default: 5.
# ROUTER_MEMORY_RECALL_COUNT=5

# ─────────────────────────────────────────────────────────────────────────────
# Desktop-control opt-in
# ─────────────────────────────────────────────────────────────────────────────

# `desktop.ps1` (mouse/keyboard/clipboard/window control) refuses every
# subcommand, including read-only screenshots, unless this is set to "1" or
# `--enable` is passed. Treats every action as surveillance until proven
# otherwise.
# AI_ROUTER_DESKTOP_ENABLED=0
